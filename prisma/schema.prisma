generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Channel {
  WHATSAPP
  WEB
}

enum ConvStatus {
  ACTIVE
  WAITING_HUMAN
  CLOSED
}

enum AgentType {
  ORCHESTRATOR
  SALES
  COLLECTIONS
  LOGISTICS
  DEPOSITS
  ADMIN
}

enum MessageRole {
  USER
  ASSISTANT
  TOOL
  SYSTEM
}

model Conversation {
  id         String     @id @default(uuid())
  threadId   String     @unique
  channel    Channel
  externalId String
  status     ConvStatus @default(ACTIVE)
  agentType  AgentType?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  messages   Message[]
  tokenUsage TokenUsage[]
  events     OrchestrationEvent[]

  @@index([externalId])
  @@index([status])
  @@index([createdAt])
}

model Message {
  id             String      @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  role           MessageRole
  content        String
  agentType      AgentType?
  createdAt      DateTime    @default(now())

  @@index([conversationId, createdAt])
}

// Las tablas del PostgresSaver (checkpoints, checkpoint_writes, checkpoint_blobs)
// son creadas y gestionadas por LangGraph. Prisma no las toca.

model TokenUsage {
  id             String        @id @default(uuid())
  conversationId String?
  conversation   Conversation? @relation(fields: [conversationId], references: [id])
  agentType      AgentType
  inputTokens    Int
  outputTokens   Int
  durationMs     Int
  model          String
  createdAt      DateTime      @default(now())

  @@index([agentType, createdAt])
}

model KnowledgeDocument {
  id        String   @id @default(uuid())
  title     String
  content   String
  category  String
  vectorId  String?
  version   Int      @default(1)
  checksum  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([category, version])
}

model OrchestrationEvent {
  id             String        @id @default(uuid())
  threadId       String
  conversationId String?
  conversation   Conversation? @relation(fields: [conversationId], references: [id])
  eventType      String
  agentType      AgentType?
  payload        Json
  createdAt      DateTime      @default(now())

  @@index([threadId])
  @@index([eventType])
  @@index([createdAt])
}