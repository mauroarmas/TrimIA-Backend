# ─── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=trimia
POSTGRES_PASSWORD=trimia
POSTGRES_DB=trimia
# Desde el host (pgAdmin, prisma migrate fuera de Docker): usa localhost:5433
# Dentro de Docker el compose inyecta postgres:5432 automáticamente
DATABASE_URL=postgresql://trimia:trimia@localhost:5433/trimia

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ─── LangGraph PostgresSaver ───────────────────────────────────────────────────
# Pool separado del de Prisma — no competir con queries de negocio
POSTGRES_SAVER_POOL_MAX=5

# ─── Google Gemini ─────────────────────────────────────────────────────────────
# Obtener en: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_api_key_here

# ─── ChromaDB ──────────────────────────────────────────────────────────────────
CHROMA_URL=http://chromadb:8000

# ─── n8n ───────────────────────────────────────────────────────────────────────
# Secret compartido entre n8n y NestJS para autenticar webhooks entrantes
N8N_WEBHOOK_SECRET=trimia-app-n8n
# URL interna de n8n para que NestJS reenvíe respuestas a WhatsApp
N8N_BASE_URL=http://n8n:5678

# ─── RAG ───────────────────────────────────────────────────────────────────────
# Umbral de confianza del contexto RAG para escalar a humano (0.0 – 1.0)
RAG_CONFIDENCE_THRESHOLD=0.7